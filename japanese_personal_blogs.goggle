! --- Zenn（エンジニア向け高品質プラットフォーム）---
$boost=3,site=zenn.dev
/articles/$boost=3,site=zenn.dev
/books/$boost=2,site=zenn.dev
! Zennのトップページ・タグ一覧などは不要なのでやや降格
/topics$downrank=1,site=zenn.dev
/users$downrank=1,site=zenn.dev

! --- Qiita（日本最大のエンジニア情報共有）---
$boost=2,site=qiita.com
/items/$boost=3,site=qiita.com
! Qiitaのランキング・タグページは個人記事より優先度低め
/tags/$downrank=1,site=qiita.com
/organizations/$downrank=1,site=qiita.com

! --- はてなブログ（個人ブログの中心地）---
! hatenablog.com（無料プラン）
$boost=2,site=hatenablog.com
/entry/$boost=3,site=hatenablog.com
! hateblo.jp
$boost=2,site=hateblo.jp
/entry/$boost=3,site=hateblo.jp
! hatenadiary.jp（旧はてなダイアリー）
